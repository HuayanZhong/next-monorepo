{
  "name": "@workspace/ui",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "catalog:dev",
    "@hugeicons/react": "catalog:dev",
    "class-variance-authority": "catalog:dev",
    "clsx": "catalog:dev",
    "next-themes": "catalog:dev",
    "radix-ui": "catalog:dev",
    "react": "catalog:dev",
    "react-dom": "catalog:dev",
    "shadcn": "catalog:dev",
    "tailwind-merge": "catalog:dev",
    "tw-animate-css": "catalog:dev",
    "zod": "catalog:dev"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "catalog:dev",
    "@turbo/gen": "catalog:dev",
    "@types/node": "catalog:dev",
    "@types/react": "catalog:dev",
    "@types/react-dom": "catalog:dev",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "catalog:dev",
    "prettier": "catalog:dev",
    "tailwindcss": "catalog:dev",
    "typescript": "catalog:dev"
  },
  "exports": {
    "./globals.css": "./src/styles/globals.css",
    "./postcss.config": "./postcss.config.mjs",
    "./lib/*": "./src/lib/*.ts",
    "./components/*": "./src/components/*.tsx",
    "./hooks/*": "./src/hooks/*.ts"
  }
}
